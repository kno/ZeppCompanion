{
  "configVersion": "v3",
  "app": {
    "appId": 1000001,
    "appName": "ZeppCompanion",
    "appType": "app",
    "version": {
      "code": 1,
      "name": "1.0.0"
    },
    "icon": "icon.png",
    "vender": "ZeppCompanion",
    "description": "A companion app for Zepp OS smartwatches"
  },
  "runtime": {
    "apiVersion": {
      "compatible": "3.0",
      "target": "3.0",
      "minVersion": "3.0"
    }
  },
  "permissions": [
    "data:user.hd.heart_rate",
    "data:user.hd.step",
    "data:user.hd.spo2",
    "data:user.hd.sleep",
    "data:user.hd.stress",
    "data:user.hd.calorie",
    "device:os.local_storage",
    "device:os.bg_service",
    "device:os.geolocation"
  ],
  "targets": {
    "amazfit-active": {
      "module": {
        "page": {
          "pages": [
            "page/home/index",
            "page/training-select/index",
            "page/pre-training/index",
            "page/active-training/index",
            "page/training-summary/index",
            "page/settings/index"
          ]
        },
        "app-side": {
          "path": "app-side/index"
        },
        "app-service": {
          "services": [
            "app-service/index"
          ]
        }
      },
      "platforms": [
        {
          "name": "amazfit-active",
          "deviceSource": 8519936,
          "st": "r",
          "sr": "w480"
        }
      ],
      "designWidth": 480
    }
  },
  "i18n": {
    "en-US": {
      "appName": "ZeppCompanion"
    },
    "es-ES": {
      "appName": "ZeppCompanion"
    }
  },
  "defaultLanguage": "en-US"
}
