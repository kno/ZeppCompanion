{
  "configVersion": "v3",
  "app": {
    "appId": 20001,
    "appName": "ZeepCompanion",
    "appType": "app",
    "version": {
      "code": 1,
      "name": "1.0.0"
    },
    "icon": "icon.png",
    "vender": "ZeepCompanion",
    "description": "Training companion with virtual pet for Zepp OS"
  },
  "permissions": ["data:os.device.info", "device:os.local_storage"],
  "runtime": {
    "apiVersion": {
      "compatible": "3.0",
      "target": "3.0",
      "minVersion": "3.0"
    }
  },
  "debug": false,
  "targets": {
    "gt": {
      "module": {
        "page": {
          "pages": [
            "page/gt/home/index.page",
            "page/gt/training-select/index.page",
            "page/gt/pre-training/index.page",
            "page/gt/active-training/index.page",
            "page/gt/training-summary/index.page",
            "page/gt/settings/index.page"
          ]
        }
      },
      "platforms": [
        {
          "st": "r"
        },
        {
          "st": "s"
        }
      ],
      "designWidth": 480
    }
  },
  "i18n": {
    "en-US": {
      "appName": "ZeepCompanion"
    }
  },
  "defaultLanguage": "en-US"
}
