generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  trainings Training[]
  sessions  TrainingSession[]
}

model Training {
  id               String @id @default(cuid())
  userId           String
  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  type             String @default("cardio_continuous") // cardio_continuous, intervals, free
  durationMinutes  Int?
  distanceMeters   Int?
  paceGoalSecPerKm Int?
  hrZones          String? // JSON string: [{min, max}]
  intervalConfig   String? // JSON string: {workSeconds, restSeconds, sets}
  messageFrequency String  @default("MEDIUM") // HIGH, MEDIUM, LOW
  companionStyle   String  @default("MOTIVATIONAL") // MOTIVATIONAL, STRICT, NEUTRAL
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sessions TrainingSession[]
}

model TrainingSession {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingId      String
  training        Training @relation(fields: [trainingId], references: [id])
  status          String   @default("ACTIVE") // ACTIVE, COMPLETED, ABANDONED
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  totalDurationSec Int?
  totalDistanceM   Float?
  avgHeartRate     Int?
  maxHeartRate     Int?
  avgPaceSecPerKm  Int?
  caloriesBurned   Int?
  totalSteps       Int?

  dataPoints SessionDataPoint[]
  messages   CompanionMessage[]
}

model SessionDataPoint {
  id           String          @id @default(cuid())
  sessionId    String
  session      TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  timestamp    DateTime        @default(now())
  heartRate    Int?
  paceSecPerKm Int?
  distanceM    Float?
  elapsedSec   Int
  progressPct  Float?

  @@index([sessionId, timestamp])
}

model CompanionMessage {
  id          String          @id @default(cuid())
  sessionId   String
  session     TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  timestamp   DateTime        @default(now())
  message     String
  tone        String          // encouraging, warning, celebratory, calm
  mascotState String          // idle, talking, celebrating, worried
  triggerData String?         // JSON string: snapshot of metrics

  @@index([sessionId, timestamp])
}
